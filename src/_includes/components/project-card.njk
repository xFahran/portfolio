<article class="project-card glass-card tilt-card" data-project-card data-category="{{ project.categories | join(' ') }}" data-reveal>
  <span class="project-index" aria-hidden="true">{{ index | formatIndex }}</span>

  {% if project.image and project.imageAlt %}
    <img class="project-image" src="{{ project.image | url }}" alt="{{ project.imageAlt }}" loading="lazy" decoding="async" />
  {% endif %}

  <div class="project-card-top">
    <span class="project-type">{{ project.type }}</span>
    <span class="project-scope">{{ project.scope }}</span>
  </div>

  <h2>{{ project.title }}</h2>
  <p>{{ project.description }}</p>

  {% if project.impact.length %}
    <div class="project-impact" aria-label="Points forts du projet">
      {% for item in project.impact %}
        <span>{{ item }}</span>
      {% endfor %}
    </div>
  {% endif %}

  {% if project.technologies.length %}
    <div class="tags" aria-label="Technologies utilisées">
      {% for technology in project.technologies %}
        <span>{{ technology }}</span>
      {% endfor %}
    </div>
  {% endif %}

  {% if project.repositoryUrl or project.demoUrl %}
    <div class="project-links" aria-label="Liens du projet">
      {% if project.repositoryUrl %}
        <a class="project-link" href="{{ project.repositoryUrl }}" target="_blank" rel="noopener noreferrer">Dépôt</a>
      {% endif %}
      {% if project.demoUrl %}
        <a class="project-link" href="{{ project.demoUrl }}" target="_blank" rel="noopener noreferrer">Démo</a>
      {% endif %}
    </div>
  {% endif %}

  {% if project.context or project.difficulties.length or project.technicalDecisions.length or project.tests.length %}
    <div class="project-details">
      {% if project.context %}
        <p>{{ project.context }}</p>
      {% endif %}
      {% if project.difficulties.length %}
        <ul>
          {% for difficulty in project.difficulties %}
            <li>{{ difficulty }}</li>
          {% endfor %}
        </ul>
      {% endif %}
      {% if project.technicalDecisions.length %}
        <ul>
          {% for decision in project.technicalDecisions %}
            <li>{{ decision }}</li>
          {% endfor %}
        </ul>
      {% endif %}
      {% if project.tests.length %}
        <ul>
          {% for test in project.tests %}
            <li>{{ test }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  {% endif %}
</article>
