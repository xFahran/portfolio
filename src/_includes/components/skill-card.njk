<article class="skill-card {{ skill.tone }}" data-skill-card data-reveal>
  <div class="skill-card-head">
    <span class="skill-icon" aria-hidden="true">{{ skill.icon }}</span>
    <span class="skill-family">{{ skill.family }}</span>
  </div>
  <h2>{{ skill.title }}</h2>
  <p>{{ skill.description }}</p>
</article>
